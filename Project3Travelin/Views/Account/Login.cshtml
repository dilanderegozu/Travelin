@model Project3Travelin.Dtos.AccountDtos.LoginDto
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_TravelinLayout.cshtml";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="row g-0 rounded-4 overflow-hidden shadow-sm w-100" style="max-width:900px; border:0.5px solid #e0e0e0;">

        <!-- Sol: İllüstrasyon -->
        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-end p-4 position-relative"
             style="background: linear-gradient(160deg, #0F6E56 0%, #1D9E75 60%, #5DCAA5 100%); min-height:500px;">
            <svg class="position-absolute top-0 start-0 w-100 h-100"
                 viewBox="0 0 300 460" preserveAspectRatio="xMidYMid slice"
                 xmlns="http://www.w3.org/2000/svg">
                <circle cx="240" cy="70" r="36" fill="rgba(255,255,255,0.08)" />
                <circle cx="260" cy="58" r="24" fill="rgba(255,255,255,0.12)" />
                <ellipse cx="150" cy="460" rx="200" ry="60" fill="rgba(0,0,0,0.15)" />
                <polygon points="40,420 120,260 200,420" fill="rgba(255,255,255,0.08)" />
                <polygon points="90,420 180,200 270,420" fill="rgba(255,255,255,0.06)" />
                <polygon points="0,420 80,300 160,420" fill="rgba(255,255,255,0.05)" />
                <line x1="230" y1="80" x2="230" y2="420" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
                <rect x="218" y="390" width="24" height="30" rx="2" fill="rgba(255,255,255,0.12)" />
                <rect x="222" y="370" width="16" height="20" rx="2" fill="rgba(255,255,255,0.1)" />
                <path d="M30 180 Q50 160 70 175 Q90 155 110 170" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" fill="none" />
                <circle cx="40" cy="155" r="22" fill="rgba(255,255,255,0.06)" />
                <circle cx="70" cy="145" r="28" fill="rgba(255,255,255,0.07)" />
                <circle cx="100" cy="152" r="20" fill="rgba(255,255,255,0.05)" />
                <circle cx="130" cy="130" r="5" fill="rgba(255,255,255,0.5)" />
                <circle cx="145" cy="118" r="3" fill="rgba(255,255,255,0.35)" />
                <circle cx="160" cy="126" r="4" fill="rgba(255,255,255,0.4)" />
            </svg>
            <div class="position-relative z-1">
                <span class="badge rounded-pill mb-2 px-3 py-2"
                      style="background:rgba(255,255,255,0.15); border:0.5px solid rgba(255,255,255,0.25); color:#E1F5EE; font-size:12px; font-weight:400;">
                    <i class="fas fa-map-marker-alt me-1"></i> Travelin
                </span>
                <h5 class="fw-normal text-white mb-1" style="line-height:1.3;">Yeni maceralar seni bekliyor</h5>
                <p class="mb-0" style="font-size:13px; color:rgba(255,255,255,0.7);">En iyi turları keşfet, anılarını paylaş.</p>
            </div>
        </div>

        <!-- Sağ: Form -->
        <div class="col-lg-6 col-12 p-4 bg-white d-flex flex-column justify-content-center">
            <p style="font-size:22px; font-weight:500; margin-bottom:4px;">Tekrar hoş geldin 👋</p>
            <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Hesabına giriş yap</p>

            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger py-2" style="font-size:13px;">
                    @TempData["LoginError"]
                </div>
            }

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <button type="button" class="btn w-100 d-flex align-items-center justify-content-center gap-2"
                            style="border:0.5px solid #e0e0e0; font-size:12px; font-weight:500; padding:8px;">
                        <i class="fab fa-facebook" style="color:#1877F2;"></i> Facebook
                    </button>
                </div>
                <div class="col-6">
                    <button type="button" class="btn w-100 d-flex align-items-center justify-content-center gap-2"
                            style="border:0.5px solid #e0e0e0; font-size:12px; font-weight:500; padding:8px;">
                        <i class="fab fa-google" style="color:#EA4335;"></i> Google
                    </button>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 mb-3">
                <hr class="flex-grow-1 m-0" style="border-color:#e0e0e0;">
                <span style="font-size:11px; color:#9ca3af;">veya e-posta ile devam et</span>
                <hr class="flex-grow-1 m-0" style="border-color:#e0e0e0;">
            </div>

            <form method="post" action="/Account/Login">
                @Html.AntiForgeryToken()
                <div class="input-group mb-2">
                    <span class="input-group-text bg-white border-end-0" style="border:0.5px solid #e0e0e0;">
                        <i class="fas fa-envelope" style="font-size:13px; color:#9ca3af;"></i>
                    </span>
                    <input asp-for="Username" type="text" class="form-control border-start-0 ps-0"
                           placeholder="E-posta veya kullanıcı adı"
                           style="font-size:13px; border:0.5px solid #e0e0e0;">
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text bg-white border-end-0" style="border:0.5px solid #e0e0e0;">
                        <i class="fas fa-lock" style="font-size:13px; color:#9ca3af;"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 ps-0"
                           placeholder="Şifre"
                           style="font-size:13px; border:0.5px solid #e0e0e0;">
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3" style="font-size:12px;">
                    <label class="d-flex align-items-center gap-1" style="cursor:pointer; color:#6b7280;">
                        <input asp-for="RememberMe" type="checkbox" style="accent-color:#1D9E75;"> Beni hatırla
                    </label>
                    <a href="#" style="color:#1D9E75; text-decoration:none;">Şifremi unuttum</a>
                </div>
                <button type="submit" class="btn w-100 text-white mb-3"
                        style="background:#1D9E75; border:none; padding:10px; font-size:14px; font-weight:500; border-radius:8px;">
                    Giriş yap
                </button>
                <p class="text-center mb-0" style="font-size:12px; color:#6b7280;">
                    Hesabın yok mu?
                    <a asp-controller="Account" asp-action="Register"
                       style="color:#1D9E75; font-weight:500; text-decoration:none;">Kayıt ol</a>
                </p>
            </form>
        </div>

    </div>
</div>