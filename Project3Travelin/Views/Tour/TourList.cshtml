@{
    Layout = null;
}

<!DOCTYPE html>

@await Component.InvokeAsync("_TourHeadComponentPartial")

@await Component.InvokeAsync("_TourHeaderComponentPartial")

  

    <!-- top Destination starts -->
@await Component.InvokeAsync("_TourListComponentPartial", new { page = ViewBag.Page ?? 1 })
    <!-- top Destination ends -->

    <!-- footer starts -->
@await Component.InvokeAsync("_TourFooterComponentPartial")
    <!-- footer ends -->
    
    <!-- Back to top start -->
    <div id="back-to-top">
        <a href="#"></a>
    </div>
    <!-- Back to top ends -->

    <!-- search popup -->
    <div id="search1">
        <button type="button" class="close">×</button>
        <form>
            <input type="search" value="" placeholder="type keyword(s) here" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>



<script>
    function switchTab(name) {
        document.getElementById('pane-login').style.display = name === 'login' ? 'block' : 'none';
        document.getElementById('pane-register').style.display = name === 'register' ? 'block' : 'none';

        const loginBtn = document.getElementById('tab-login');
        const registerBtn = document.getElementById('tab-register');

        if (name === 'login') {
            loginBtn.style.background = '#fff';
            loginBtn.style.border = '0.5px solid #e0e0e0';
            loginBtn.style.color = '#111';
            registerBtn.style.background = 'transparent';
            registerBtn.style.border = 'none';
            registerBtn.style.color = '#6b7280';
        } else {
            registerBtn.style.background = '#fff';
            registerBtn.style.border = '0.5px solid #e0e0e0';
            registerBtn.style.color = '#111';
            loginBtn.style.background = 'transparent';
            loginBtn.style.border = 'none';
            loginBtn.style.color = '#6b7280';
        }
    }
</script>


    <!-- *Scripts* -->
