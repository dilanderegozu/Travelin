@using Project3Travelin.Dtos.CategoryDtos
@model List<ResultTourDto>
@{
    Layout = "~/Views/Shared/_TravelinLayout.cshtml";
   
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}


<!-- BreadCrumb Starts -->
<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/images/bg/bg1.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">Tur Listesi</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Dashboard/Index">Ana Sayfa</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Aktif Tur Listesi</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>
<!-- BreadCrumb Ends -->
<!-- top Destination starts -->
<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="list-results d-flex align-items-center justify-content-between">
                    <div class="list-results-sort">
                        <p class="m-0">@ViewBag.StartItem-@ViewBag.EndItem arası gösteriliyor, toplam @ViewBag.TotalCount sonuç bulundu</p>
                    </div>
                    <div class="click-menu d-flex align-items-center justify-content-between">
                        <div class="change-list f-active me-2">
                            <a href="/Tour/TourList"><i class="fa fa-bars rounded"></i></a>
                        </div>
                        <div class="change-grid me-2">
                            <a href="/Tour/TourListGrid"><i class="fa fa-th rounded"></i></a>
                        </div>
                        <div class="sortby d-flex align-items-center justify-content-between ml-2">
                            <select class="niceSelect">
                                <option value="1">Sırala</option>
                                <option value="2">Ortalama Puan</option>
                                <option value="3">Fiyat: Düşükten Yükseğe</option>
                                <option value="4">Fiyat: Yüksekten Düşüğe</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">

                    @foreach (var item in Model)
                    {
                        <div class="col-lg-6 col-md-6 mb-4">
                            <div class="trend-item rounded box-shadow">
                                <div class="trend-image position-relative">
                                    <img src="@item.ImageUrl" alt="image" class="">
                                    <div class="color-overlay"></div>
                                </div>
                                <div class="trend-content p-4 pt-5 position-relative">
                                    <div class="trend-meta bg-theme white px-3 py-2 rounded">
                                        <div class="entry-author">
                                            <i class="icon-calendar"></i>
                                            <span class="fw-bold"> @item.DayNight</span>
                                        </div>
                                    </div>
                                    <h5 class="theme mb-1"><i class="flaticon-location-pin"></i> @item.Country</h5>
                                    <h3 class="mb-1"><a href="tour-single.html">@item.City</a></h3>
                                    <div class="rating-main d-flex align-items-center pb-2">
                                        <div class="rating">
                                            @for (int star = 1; star <= 5; star++)
                                            {
                                                if (star <= (int)Math.Round(item.Rating))
                                                {
                                                    <span class="fa fa-star" style="color: #f5a623;"></span>
                                                }
                                                else
                                                {
                                                    <span class="fa fa-star" style="color: #d1d5db;"></span>
                                                }
                                            }
                                        </div>
                                        <span class="ms-2">@ViewBag.CommentCount</span>
                                    </div>
                                    <p class=" border-b pb-2 mb-2">@item.Description</p>
                                    <div class="entry-meta">
                                        <div class="entry-author d-flex align-items-center">
                                            <p class="mb-0"><span class="theme fw-bold fs-5"> @item.Price  @item.Currency</span> | Kişi Başı</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                    @if (totalPages > 1)
                    {
                        <div class="col-lg-12 mt-4">
                            <div class="d-flex justify-content-center align-items-center gap-2">

                                @if (currentPage > 1)
                                {
                                    <a href="/Tour/TourList?page=@(currentPage - 1)"
                                       class="nir-btn">
                                        <i class="fa fa-chevron-left"></i>
                                    </a>
                                }

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <a href="/Tour/TourList?page=@i"
                                       class="nir-btn @(i == currentPage ? "active" : "")">
                                        @i
                                    </a>
                                }

                                @if (currentPage < totalPages)
                                {
                                    <a href="/Tour/TourList?page=@(currentPage + 1)"
                                       class="nir-btn">
                                        <i class="fa fa-chevron-right"></i>
                                    </a>
                                }

                            </div>
                        </div>
                    }

                
                </div>
            </div>
            <div class="col-lg-4 ps-lg-4">
                <div class="sidebar-sticky">
                    <div class="list-sidebar">
                        <div class="sidebar-item mb-4">
                            <h3 class="">Kategori Türleri</h3>
                            <ul class="sidebar-category1">
                              @foreach (var item in (List<ResultCategoryDto>)ViewBag.Categories)
{
    <li>
        <input type="checkbox">
        @item.CategoryName
    </li>
}
                              
                            </ul>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- top Destination ends -->
