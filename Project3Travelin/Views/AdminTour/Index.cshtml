@model List<Project3Travelin.Entities.Reservation>
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
    int colorIndex = 0;
    var colorHex = new[] { "#b2c5ff", "#fd8b00", "#404446", "#dee9ff", "#ba1a1a", "#dae2ff" };
    var dist = ViewBag.CategoryDistribution as IEnumerable<dynamic>;
}
<main class="p-container-padding pb-20">
        <!-- Header Section -->
        <header class="mb-8">
            <h2 class="font-display-lg text-display-lg text-on-surface">Ana Sayfa</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Sisteme genel bakış ve performans özetini buradan takip edebilirsiniz.</p>
        </header>
        <!-- Statistics Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">

        <div class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-amber-800 text-2xl">group</span>
            </div>
            <div>
                <p class="text-xs text-gray-400 mb-1">Toplam Müşteri</p>
                <p class="text-3xl font-bold text-gray-900">@ViewBag.TotalCustomers</p>
            </div>
            <div class="h-1 rounded-full bg-amber-50">
                <div class="h-full w-[70%] rounded-full bg-amber-400"></div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-800 text-2xl">calendar_month</span>
            </div>
            <div>
                <p class="text-xs text-gray-400 mb-1">Toplam Rezervasyon</p>
                <p class="text-3xl font-bold text-gray-900">@ViewBag.TotalReservations</p>
            </div>
            <div class="h-1 rounded-full bg-blue-50">
                <div class="h-full w-[85%] rounded-full bg-blue-400"></div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-orange-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-orange-800 text-2xl">schedule</span>
            </div>
            <div>
                <p class="text-xs text-gray-400 mb-1">Bekleyen Rezervasyon</p>
                <p class="text-3xl font-bold text-gray-900">@ViewBag.PendingReservations</p>
            </div>
            <div class="h-1 rounded-full bg-orange-50">
                <div class="h-full w-[40%] rounded-full bg-orange-400"></div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-xl bg-green-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-800 text-2xl">check_circle</span>
            </div>
            <div>
                <p class="text-xs text-gray-400 mb-1">Onaylanan Rezervasyon</p>
                <p class="text-3xl font-bold text-gray-900">@ViewBag.ApprovedReservations</p>
            </div>
            <div class="h-1 rounded-full bg-green-50">
                <div class="h-full w-[55%] rounded-full bg-green-400"></div>
            </div>
        </div>

    </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter mb-8">
            <!-- Sales Analysis (Line Chart Placeholder) -->
        <div class="lg:col-span-2 bg-surface-container-lowest p-6 rounded-xl custom-shadow">
    <div class="flex justify-between items-center mb-6">
        <h3 class="font-headline-md text-headline-md">Aylık Rezervasyon Analizi</h3>
        <select id="chart-range" class="text-label-sm border border-outline-variant rounded-lg bg-surface focus:ring-primary px-3 py-1">
            <option value="6">Son 6 Ay</option>
            <option value="12">Son 1 Yıl</option>
        </select>
    </div>
    <div class="h-64">
        <canvas id="reservationChart"></canvas>
    </div>
</div>

@section Scripts {
<script>
    const data6  = { labels: @Html.Raw(ViewBag.ChartLabels6),  values: @Html.Raw(ViewBag.ChartData6)  };
    const data12 = { labels: @Html.Raw(ViewBag.ChartLabels12), values: @Html.Raw(ViewBag.ChartData12) };

    const ctx = document.getElementById('reservationChart').getContext('2d');
    const chart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: data6.labels,
            datasets: [{
                label: 'Rezervasyon',
                data: data6.values,
                backgroundColor: '#b2c5ff',
                hoverBackgroundColor: '#0052cc',
                borderRadius: 6,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 },
                    grid: { color: 'rgba(0,0,0,0.05)' }
                },
                x: { grid: { display: false } }
            }
        }
    });

    document.getElementById('chart-range').addEventListener('change', function () {
        const d = this.value === '12' ? data12 : data6;
        chart.data.labels = d.labels;
        chart.data.datasets[0].data = d.values;
        chart.update();
    });
</script>
}
            <!-- Distribution (Donut Chart Placeholder) -->
            <div class="bg-surface-container-lowest p-6 rounded-xl custom-shadow flex flex-col">
                <h3 class="font-headline-md text-headline-md mb-6">Rezervasyon Dağılımı</h3>
                <div class="flex-1 flex items-center justify-center relative">
                    <div class="w-40 h-40 rounded-full border-[12px] border-primary-container border-t-secondary-container border-l-tertiary border-r-surface-container-high animate-[spin_3s_ease-in-out_infinite_alternate]"></div>
                    <div class="absolute flex flex-col items-center">
                    <span class="text-body-md font-bold">@ViewBag.TotalReservations</span>
                        <span class="text-[10px] text-on-surface-variant uppercase">Toplam</span>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2 mt-6">
          @foreach (var item in dist)
{
    <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: @colorHex[colorIndex % colorHex.Length];"></span>
        <span class="text-label-sm flex-1">@item.CategoryName</span>
  
    </div>
    { colorIndex++; }
}

                
                </div>
            </div>
        </div>
        <!-- Bottom Section: Tables and Popularity -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            <!-- Recent Reservations Table -->
        @await Component.InvokeAsync("_AdminLastReservationComponentPartial")
     
            <!-- Popular Tours -->
        <div class="bg-surface-container-lowest p-6 rounded-xl custom-shadow">
            <h3 class="font-headline-md text-headline-md mb-6">Popüler Turlar</h3>
            <div class="space-y-6">
                @{
                    var topTours = ViewBag.TopTours as IEnumerable<dynamic>;
                }
                @if (topTours != null)
                {
                    @foreach (var tour in topTours)
                    {
                        <div class="flex items-center gap-4">
                            <img class="w-14 h-14 rounded-lg object-cover" src="@tour.ImageUrl" />
                            <div class="flex-1">
                                <p class="font-body-md font-semibold text-on-surface">@tour.Title</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <div class="flex-1 h-1.5 bg-surface-container-high rounded-full overflow-hidden">
                                        <div class="h-full bg-primary" style="width:100%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
        </div>
</main>