@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}
<section class="p-container-padding flex-1 overflow-x-hidden">
    <!-- Page Header -->
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h2 class="font-display-lg text-display-lg text-on-surface">Müşteri Listesi</h2>
            <p class="text-on-surface-variant font-body-lg text-body-lg mt-1">Kayıtlı müşterilerin bilgilerini yönetin ve seyahat geçmişlerini inceleyin.</p>
        </div>
        <div class="flex gap-3">
            <button class="bg-surface-container-lowest border border-outline-variant text-on-surface px-4 py-2.5 rounded-lg flex items-center gap-2 hover:bg-surface-container-low transition-colors shadow-sm">
                <span class="material-symbols-outlined text-outline">download</span>
                <span class="font-body-md text-body-md">CSV'ye Aktar</span>
            </button>
            <button class="bg-primary text-on-primary px-4 py-2.5 rounded-lg flex items-center gap-2 hover:opacity-90 transition-all shadow-sm active:scale-95">
                <span class="material-symbols-outlined">person_add</span>
                <span class="font-body-md text-body-md">Yeni Müşteri Ekle</span>
            </button>
        </div>
    </div>
    <!-- Statistics Cards - Bento Layout -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-8">
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] flex items-center gap-5 transition-transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-primary-container/10 rounded-full flex items-center justify-center text-primary">
                <span class="material-symbols-outlined" style="font-size: 32px;">group</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Toplam Müşteri</p>
                <h3 class="text-2xl font-bold text-on-surface">1,240</h3>
                <p class="text-primary font-label-sm text-label-sm mt-1 flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">trending_up</span> +12% geçen aya göre
                </p>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] flex items-center gap-5 transition-transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-secondary-container/10 rounded-full flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined" style="font-size: 32px;">verified_user</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Aktif Müşteriler</p>
                <h3 class="text-2xl font-bold text-on-surface">892</h3>
                <p class="text-on-surface-variant font-label-sm text-label-sm mt-1">Şu an seyahatte olan: 24</p>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] flex items-center gap-5 transition-transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-tertiary-container/10 rounded-full flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined" style="font-size: 32px;">person_add</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Bu Ay Yeni</p>
                <h3 class="text-2xl font-bold text-on-surface">156</h3>
                <p class="text-error font-label-sm text-label-sm mt-1 flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">trending_down</span> -2% geçen aya göre
                </p>
            </div>
        </div>
