@model List<AppUser>
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
    var userStats = ViewBag.UserStats as IEnumerable<dynamic>;
}

<section class="p-container-padding flex-1 overflow-x-hidden">
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h2 class="font-display-lg text-display-lg text-on-surface">Müşteri Listesi</h2>
            <p class="text-on-surface-variant font-body-lg text-body-lg mt-1">Kayıtlı müşterilerin bilgilerini yönetin ve seyahat geçmişlerini inceleyin.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-gutter mb-8">
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] flex items-center gap-5">
            <div class="w-14 h-14 bg-primary-container/10 rounded-full flex items-center justify-center text-primary">
                <span class="material-symbols-outlined" style="font-size:32px;">group</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Toplam Müşteri</p>
                <h3 class="text-2xl font-bold text-on-surface">@ViewBag.TotalCustomers</h3>
            </div>
        </div>
    </div>

    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-low border-b border-outline-variant">
                    <tr>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Müşteri</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">E-Posta</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-center">Toplam Tur</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Son Rezervasyon</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container-low">
                    @if (userStats != null)
                    {
                        @foreach (var stat in userStats)
                        {
                            AppUser user = stat.User;
                            int tourCount = stat.TourCount;
                            DateTime? lastRes = stat.LastReservation;

                            <tr class="hover:bg-surface-container-lowest transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center font-bold text-primary text-sm flex-shrink-0">
                                            @(user.FirstName?[0].ToString().ToUpper())@(user.LastName?[0].ToString().ToUpper())
                                        </div>
                                        <div>
                                            <p class="font-bold text-on-surface font-body-md">@user.FirstName @user.LastName</p>
                                            <span class="text-xs px-2 py-0.5 rounded-full @(tourCount >= 5 ? "bg-primary/10 text-primary" : tourCount == 0 ? "bg-secondary-container/10 text-secondary" : "bg-tertiary-container/10 text-tertiary") font-semibold">
                                                @(tourCount >= 5 ? "VIP" : tourCount == 0 ? "Yeni" : "Regular")
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-body-md text-body-md text-on-surface-variant">@user.Email</td>
                                <td class="px-6 py-4 font-body-md text-body-md text-on-surface text-center font-semibold">@tourCount</td>
                                <td class="px-6 py-4 font-body-md text-body-md text-on-surface-variant">
                                    @(lastRes.HasValue ? lastRes.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <form method="post" asp-action="DeleteCustomer" asp-controller="AdminTour"
                                              onsubmit="return confirm('Bu müşteriyi silmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="p-2 hover:bg-surface-container rounded-lg text-error transition-colors" title="Sil">
                                                <span class="material-symbols-outlined">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex items-center justify-between">
            <p class="text-on-surface-variant font-label-sm text-label-sm">Toplam @ViewBag.TotalCustomers müşteri</p>
        </div>
    </div>
</section>