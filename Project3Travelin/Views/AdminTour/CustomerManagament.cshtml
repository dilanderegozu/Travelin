        </div>
        <select class="min-w-[180px] bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 font-body-md text-body-md focus:ring-2 focus:ring-primary outline-none">
            <option value="">Ülke Filtrele</option>
            <option value="tr">Türkiye</option>
            <option value="de">Almanya</option>
            <option value="uk">İngiltere</option>
            <option value="us">ABD</option>
