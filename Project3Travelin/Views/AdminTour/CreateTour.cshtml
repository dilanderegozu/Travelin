@model Project3Travelin.Dtos.TourDtos.CreateTourDto
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<form method="post" asp-action="CreateTour" asp-controller="AdminTour" id="create-form">
    @Html.AntiForgeryToken()
    <main class="ml-[sidebar-width] pt-[header-height] min-h-screen p-container-padding pb-32">

        <nav class="flex items-center gap-2 text-on-surface-variant font-label-sm mb-4">
            <a href="/AdminTour/Index" class="hover:text-primary">Ana Sayfa</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <a href="/AdminTour/TourList" class="hover:text-primary">Tur Yönetimi</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="text-primary font-bold">Yeni Tur Ekle</span>
        </nav>

        <div class="flex justify-between items-end mb-8">
            <div>
                <h3 class="font-display-lg text-display-lg text-on-surface">Yeni Tur Ekle</h3>
                <p class="text-on-surface-variant mt-1 font-body-md">Sisteme yeni bir gezi rotası ve detaylarını ekleyin.</p>
            </div>
            <div class="flex gap-3">
                <a href="/AdminTour/TourList" class="px-6 py-2.5 rounded-lg border border-primary text-primary font-bold hover:bg-surface-container-low">İptal</a>
                <button type="submit" class="px-8 py-2.5 rounded-lg bg-primary text-white font-bold hover:bg-primary-container shadow-md">Kaydet</button>
            </div>
        </div>

        <div class="grid grid-cols-12 gap-6">
            <div class="col-span-12 lg:col-span-8 space-y-6">

                <!-- Temel Bilgiler -->
                <div class="bg-surface-container-lowest p-6 rounded-lg border border-outline-variant/30">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined text-[20px]">info</span>
                        </div>
                        <h4 class="font-headline-md text-headline-md">Temel Bilgiler</h4>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Başlığı</label>
                            <input asp-for="Title" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Ülke</label>
                                <input asp-for="Country" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Şehir</label>
                                <input asp-for="City" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Tarihi</label>
                                <input asp-for="TourDate" type="date" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Gün / Gece</label>
                                <input asp-for="DayNight" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Kalkış Noktası</label>
                                <input asp-for="DepartureLocation" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Dönüş Noktası</label>
                                <input asp-for="ReturnLocation" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Alış Noktası</label>
                                <input asp-for="PickupLocation" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Kalkış Saati</label>
                                <input asp-for="DepartureTime" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Minimum Yaş</label>
                                <input asp-for="MinAge" type="number" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Oda Sayısı</label>
                                <input asp-for="BedroomCount" type="number" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Enlem</label>
                                <input asp-for="Latitude" type="number" step="any" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Boylam</label>
                                <input asp-for="Longitude" type="number" step="any" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-label-sm font-bold text-on-surface mb-1.5">Durum</label>
                                <div class="flex items-center gap-3 p-3 bg-surface-container-low border border-outline-variant rounded-lg">
                                    <input asp-for="IsStatus" type="checkbox" class="h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" id="isStatus" />
                                    <label for="isStatus" class="text-body-md cursor-pointer">Aktif</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Açıklama -->
                <div class="bg-surface-container-lowest p-6 rounded-lg border border-outline-variant/30">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined text-[20px]">subject</span>
                        </div>
                        <h4 class="font-headline-md text-headline-md">Tur Detayları</h4>
                    </div>
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Açıklama</label>
                        <textarea asp-for="Description" rows="6" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none"></textarea>
                    </div>
                </div>

            </div>

            <!-- Sağ Kolon -->
            <div class="col-span-12 lg:col-span-4 space-y-6">

                <!-- Kapasite & Fiyat -->
                <div class="bg-surface-container-lowest p-6 rounded-lg border border-outline-variant/30">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-full bg-secondary-container/10 flex items-center justify-center text-secondary-container">
                            <span class="material-symbols-outlined text-[20px]">payments</span>
                        </div>
                        <h4 class="font-headline-md text-headline-md">Kapasite & Fiyat</h4>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Toplam Kapasite</label>
                            <div class="flex items-center gap-3">
                                <input asp-for="Capacity" type="number" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                                <span class="text-on-surface-variant font-label-sm whitespace-nowrap">Kişi</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Fiyat</label>
                            <div class="relative">
                                <span class="absolute left-3 top-3 text-on-surface-variant font-bold">₺</span>
                                <input asp-for="Price" type="number" step="0.01" class="w-full pl-8 bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Para Birimi</label>
                            <select asp-for="Currency" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                                <option value="TRY">TRY</option>
                                <option value="USD">USD</option>
                                <option value="EUR">EUR</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Sınıflandırma & Görsel -->
                <div class="bg-surface-container-lowest p-6 rounded-lg border border-outline-variant/30">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined text-[20px]">category</span>
                        </div>
                        <h4 class="font-headline-md text-headline-md">Sınıflandırma</h4>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Kategori</label>
                            <input asp-for="CategoryName" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Görsel URL</label>
                            <input asp-for="ImageUrl" id="image-url-input" class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div id="image-preview" class="hidden">
                            <img id="preview-img" class="w-full h-40 object-cover rounded-lg border border-outline-variant" src="" />
                        </div>
                    </div>
                </div>

                <!-- İpucu -->
                <div class="bg-primary/5 p-6 rounded-lg border border-primary/20">
                    <p class="font-bold text-primary flex items-center gap-2 mb-2">
                        <span class="material-symbols-outlined text-sm">lightbulb</span>
                        İpucu
                    </p>
                    <p class="text-body-md text-on-surface-variant leading-relaxed">
                        Yüksek çözünürlüklü görseller ve detaylı tur programı açıklamaları ekleyerek turunuzu daha dikkat çekici hale getirin.
                    </p>
                </div>

            </div>
        </div>
    </main>
</form>

@section Scripts {
    <script>
        document.getElementById('image-url-input').addEventListener('input', function () {
            const url = this.value.trim();
            const preview = document.getElementById('image-preview');
            const img = document.getElementById('preview-img');
            if (url) {
                img.src = url;
                preview.classList.remove('hidden');
            } else {
                preview.classList.add('hidden');
            }
        });
    </script>
}