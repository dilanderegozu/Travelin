@model GetTourByIdDto

@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

        <div class="flex-1 p-container-padding">
            <!-- Breadcrumbs & Header -->
            <div class="mb-8">
                <nav class="flex items-center gap-2 text-on-surface-variant text-label-sm mb-2">
                    <a class="hover:text-primary" href="#">Ana Sayfa</a>
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                    <a class="hover:text-primary" href="#">Tur Yönetimi</a>
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                    <span class="text-primary font-semibold">Tur Güncelleme</span>
                </nav>
                <div class="flex justify-between items-end">
                    <div>
                        <h2 class="font-display-lg text-display-lg text-primary">Tur Güncelleme</h2>
                        <p class="text-on-surface-variant">Kapadokya Masalı (ID: #TR-7241) tur bilgilerini düzenleyin.</p>
                    </div>
                    <div class="flex gap-3">
                        <button class="px-6 py-2.5 rounded-lg border border-primary text-primary font-semibold hover:bg-primary-fixed transition-colors">İptal</button>
                        <button class="px-6 py-2.5 rounded-lg bg-primary-container text-white font-semibold hover:bg-primary transition-all shadow-sm active:scale-95">Değişiklikleri Kaydet</button>
                    </div>
                </div>
            </div>
    <div class="grid grid-cols-12 gap-6">
        <!-- Left Column: Primary Data -->
        <div class="col-span-12 lg:col-span-8 space-y-6">
            <!-- Section 1: Temel Bilgiler -->
            <div class="bg-surface-container-lowest p-6 rounded-lg card-shadow border border-outline-variant/30">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-[20px]">info</span>
                    </div>
                    <h4 class="font-headline-md text-headline-md">Temel Bilgiler</h4>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Başlığı</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Örn: Kapadokya Rüya Turu" type="text" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Ülke</label>
                            <select class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none appearance-none">
                                <option>Türkiye</option>
                                <option>İtalya</option>
                                <option>Fransa</option>
                                <option>Yunanistan</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Şehir</label>
                            <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Şehir giriniz" type="text" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Tarihi</label>
                            <div class="relative">
                                <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" type="date" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-label-sm font-bold text-on-surface mb-1.5">Gün / Gece</label>
                            <select class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none appearance-none">
                                <option>3 Gün / 2 Gece</option>
                                <option>4 Gün / 3 Gece</option>
                                <option>7 Gün / 6 Gece</option>
                                <option>10 Gün / 9 Gece</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Section 3: Tur Detayları -->
            <div class="bg-surface-container-lowest p-6 rounded-lg card-shadow border border-outline-variant/30">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-[20px]">subject</span>
                    </div>
                    <h4 class="font-headline-md text-headline-md">Tur Detayları</h4>
                </div>
                <div>
                    <label class="block text-label-sm font-bold text-on-surface mb-1.5">Açıklama</label>
                    <textarea class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Tur programı, gezilecek yerler ve genel bilgiler..." rows="6"></textarea>
                </div>
            </div>
        </div>
        <!-- Right Column: Metadata & Assets -->
        <div class="col-span-12 lg:col-span-4 space-y-6">
            <!-- Section 2: Kapasite ve Fiyatlandırma -->
            <div class="bg-surface-container-lowest p-6 rounded-lg card-shadow border border-outline-variant/30">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-8 rounded-full bg-secondary-container/10 flex items-center justify-center text-secondary-container">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">payments</span>
                    </div>
                    <h4 class="font-headline-md text-headline-md">Kapasite &amp; Fiyat</h4>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Toplam Kapasite</label>
                        <div class="flex items-center">
                            <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" type="number" value="20" />
                            <span class="ml-3 text-on-surface-variant font-label-sm">Kişi</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Fiyat</label>
                        <div class="relative">
                            <span class="absolute left-3 top-3 text-on-surface-variant font-bold">₺</span>
                            <input class="w-full pl-8 bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="0.00" type="text" />
                            <select class="absolute right-2 top-2 border-none bg-surface-container rounded-md text-label-sm py-1 focus:ring-0">
                                <option>TRY</option>
                                <option>USD</option>
                                <option>EUR</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Section 4: Kategori ve Görsel -->
            <div class="bg-surface-container-lowest p-6 rounded-lg card-shadow border border-outline-variant/30">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-[20px]">category</span>
                    </div>
                    <h4 class="font-headline-md text-headline-md">Sınıflandırma</h4>
                </div>
                <div class="space-y-6">
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Kategorisi</label>
                        <select class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none appearance-none">
                            <option>Kültür Turu</option>
                            <option>Doğa &amp; Macera</option>
                            <option>Yaz Tatili</option>
                            <option>Gurme Turları</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-label-sm font-bold text-on-surface mb-1.5">Tur Görseli</label>
                        <div class="mt-2 border-2 border-dashed border-outline-variant rounded-lg p-8 flex flex-col items-center justify-center bg-surface-container-low hover:bg-surface-container transition-colors cursor-pointer group" id="upload-area">
                            <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant mb-3 group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                                <span class="material-symbols-outlined">cloud_upload</span>
                            </div>
                            <p class="text-body-md font-bold text-on-surface">Görsel Yükle</p>
                            <p class="text-[11px] text-on-surface-variant mt-1 text-center">PNG, JPG up to 10MB<br />(Önerilen: 1200x800px)</p>
                        </div>
                        <div class="mt-4 hidden" id="preview-area">
                            <div class="relative group">
                                <img class="w-full h-40 object-cover rounded-lg shadow-sm border border-outline-variant" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqKCimL4RmSz88dEuxECyi63_hsFe1YM6BS13Vxbv0NOarSuMIitJ61CKGVpxh_c3QaRx3RLyzolkVoVqmwMcUSPydvCLG06H3sJJP1XJOi6juOJmns4WC_GG1js3mPh_5YsM50Knjf0MPT6fne2X339uxxer1HEPWWJhjBCln3Yug3LhUzDa09az4tRRyU7Vju6jqje7cZa3qZzIVs9vbfDSNvnFbJohGlG_fd1ron8Igx2JHnxTFtvXxC3prUWxo7IAb8lCdo7c" />
                                <button class="absolute top-2 right-2 w-8 h-8 bg-error text-white rounded-full flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition-opacity">
                                    <span class="material-symbols-outlined text-sm">close</span>
                                </button>
                            </div>
                            <p class="text-[11px] text-on-surface-variant mt-2 italic">Görsel başarıyla seçildi: cappadocia_main.jpg</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Quick Help -->
            <div class="bg-primary/5 p-6 rounded-lg border border-primary/20">
                <p class="font-bold text-primary flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-sm">lightbulb</span>
                    İpucu
                </p>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Turlarınızı daha dikkat çekici kılmak için yüksek çözünürlüklü görseller ve detaylı tur programı açıklamaları eklemeyi unutmayın.
                </p>
            </div>
        </div>
    </div>
        </div>
      
    </main>
   