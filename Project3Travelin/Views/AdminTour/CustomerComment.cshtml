@model List<Project3Travelin.Dtos.CommentDtos.ResultCommentDto>
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<div class="p-container-padding space-y-gutter">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h2 class="font-display-lg text-display-lg text-primary">Müşteri Yorumları</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Turlara gelen geri bildirimleri yönetin ve onaylayın.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant flex flex-col justify-between">
            <div class="p-2 bg-primary-fixed rounded-lg w-fit">
                <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1;">star</span>
            </div>
            <div class="mt-4">
                <p class="text-on-surface-variant text-label-sm font-label-sm uppercase tracking-wider">Ortalama Puan</p>
                <h3 class="text-3xl font-bold text-primary mt-1">@ViewBag.AverageScore / 5.0</h3>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant flex flex-col justify-between">
            <div class="p-2 bg-secondary-fixed rounded-lg w-fit">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">reviews</span>
            </div>
            <div class="mt-4">
                <p class="text-on-surface-variant text-label-sm font-label-sm uppercase tracking-wider">Toplam Yorum</p>
                <h3 class="text-3xl font-bold text-primary mt-1">@ViewBag.TotalComments</h3>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant flex flex-col justify-between">
            <div class="p-2 bg-error-container rounded-lg w-fit">
                <span class="material-symbols-outlined text-error" style="font-variation-settings:'FILL' 1;">pending_actions</span>
            </div>
            <div class="mt-4">
                <p class="text-on-surface-variant text-label-sm font-label-sm uppercase tracking-wider">Onay Bekleyen</p>
                <h3 class="text-3xl font-bold text-error mt-1">@ViewBag.PendingComments</h3>
            </div>
        </div>
    </div>

    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden">
        <div class="p-6 border-b border-outline-variant bg-surface-container-low/50">
            <h3 class="font-headline-md text-headline-md text-primary">Tüm Yorumlar</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-high">
                    <tr>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant">MÜŞTERİ</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant">YORUM</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant">PUAN</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant">TARİH</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant">DURUM</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant text-right">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-container-high">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 rounded-full bg-primary-fixed flex items-center justify-center font-bold text-primary text-sm">
                                        @(item.NameSurname?.Length > 1 ? item.NameSurname.Substring(0, 2).ToUpper() : "??")
                                    </div>
                                    <div>
                                        <div class="font-bold text-sm">@item.NameSurname</div>
                                        <div class="text-xs text-on-surface-variant">@item.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 max-w-[280px]">
                                <p class="text-sm font-semibold text-on-surface mb-1">@item.HeadLine</p>
                                <p class="text-sm text-on-surface-variant line-clamp-2 italic">"@item.CommentDetail"</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex text-secondary">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="material-symbols-outlined text-[16px]"
                                              style="font-variation-settings:'FILL' @(i <= item.Score ? "1" : "0");">star</span>
                                    }
                                </div>
                                <div class="text-[11px] text-on-surface-variant mt-0.5">@item.Score / 5</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-on-surface-variant">
                                @item.CommentDate.ToString("dd MMM yyyy")
                            </td>
                            <td class="px-6 py-4">
                                @if (item.IsStatus)
                                {
                                    <span class="bg-green-100 text-green-800 text-[11px] font-bold px-2 py-1 rounded-full">YAYINLANDI</span>
                                }
                                else
                                {
                                    <span class="bg-error-container text-error text-[11px] font-bold px-2 py-1 rounded-full">ONAY BEKLİYOR</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    @if (!item.IsStatus)
                                    {
                                        <form method="post" asp-action="ApproveComment" asp-controller="AdminTour">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.CommentId" />
                                            <button type="submit"
                                                    class="bg-primary text-white text-xs px-3 py-1.5 rounded-lg hover:opacity-90 font-semibold transition-all">
                                                Onayla
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-action="DeleteComment" asp-controller="AdminTour"
                                          onsubmit="return confirm('Bu yorumu silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.CommentId" />
                                        <button type="submit"
                                                class="p-2 hover:bg-surface-container-high rounded-full text-error transition-colors">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-6 border-t border-outline-variant bg-surface-container-low/30 flex justify-between items-center">
            <span class="text-sm text-on-surface-variant">Toplam @Model.Count yorum</span>
        </div>
    </div>
</div>