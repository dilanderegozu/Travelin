@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}
  <div class="p-container-padding flex-1 space-y-8">
            <!-- Page Header & Date Picker -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div>
                    <h2 class="font-display-lg text-display-lg text-primary">Satış Raporları</h2>
                    <p class="font-body-lg text-body-lg text-on-surface-variant">Finansal performansı, satış trendlerini ve gelir dağılımını analiz edin.</p>
                </div>
                <div class="flex items-center gap-3 bg-white p-2 rounded-xl border border-outline-variant shadow-sm">
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-container-low rounded-lg border border-outline-variant cursor-pointer hover:bg-surface-container transition-colors">
                        <span class="material-symbols-outlined text-sm text-primary">calendar_today</span>
                        <span class="text-body-md font-medium">01 Oca 2024 - 31 Mar 2024</span>
                    </div>
                    <button class="bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-lg font-body-md font-semibold flex items-center gap-2 shadow-md transition-all active:scale-95">
                        <span class="material-symbols-outlined text-sm">download</span>
                        Dışa Aktar
                    </button>
                </div>
            </div>
            <!-- Summary Statistics Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
                <!-- Card 1 -->
                <div class="bg-white p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] hover:shadow-lg transition-all group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-primary-fixed text-primary rounded-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
                        </div>
                        <span class="text-success text-xs font-bold bg-green-100 text-green-700 px-2 py-1 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_up</span> 12%
                        </span>
                    </div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Brüt Gelir</p>
                    <h3 class="text-[28px] font-bold text-on-surface mt-1">₺1,240,500</h3>
                    <p class="text-outline text-[12px] mt-2">Geçen döneme göre artış</p>
                </div>
                <!-- Card 2 -->
                <div class="bg-white p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] hover:shadow-lg transition-all group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-secondary-fixed text-secondary rounded-xl group-hover:bg-secondary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">savings</span>
                        </div>
                        <span class="text-success text-xs font-bold bg-green-100 text-green-700 px-2 py-1 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_up</span> 8.4%
                        </span>
                    </div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Net Kar</p>
                    <h3 class="text-[28px] font-bold text-on-surface mt-1">₺342,200</h3>
                    <p class="text-outline text-[12px] mt-2">Komisyonlar sonrası net</p>
                </div>
                <!-- Card 3 -->
                <div class="bg-white p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] hover:shadow-lg transition-all group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-tertiary-fixed text-tertiary rounded-xl group-hover:bg-tertiary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sell</span>
                        </div>
                        <span class="text-error text-xs font-bold bg-red-100 text-red-700 px-2 py-1 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_down</span> 2.1%
                        </span>
                    </div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Ort. Rezervasyon</p>
                    <h3 class="text-[28px] font-bold text-on-surface mt-1">₺4,150</h3>
                    <p class="text-outline text-[12px] mt-2">Kişi başı ortalama harcama</p>
                </div>
                <!-- Card 4 -->
                <div class="bg-white p-6 rounded-xl border border-outline-variant shadow-[0px_2px_4px_rgba(0,0,0,0.05)] hover:shadow-lg transition-all group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-3 bg-surface-container-highest text-primary rounded-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">analytics</span>
                        </div>
                        <span class="text-success text-xs font-bold bg-green-100 text-green-700 px-2 py-1 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_up</span> 4%
                        </span>
                    </div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">Dönüşüm Oranı</p>
                    <h3 class="text-[28px] font-bold text-on-surface mt-1">14.8%</h3>
                    <p class="text-outline text-[12px] mt-2">Ziyaretçi / Satış oranı</p>
                </div>
            </div>
            <!-- Charts Section -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
                <!-- Revenue Line Chart -->
                <div class="lg:col-span-2 bg-white p-6 rounded-xl border border-outline-variant shadow-sm flex flex-col">
                    <div class="flex justify-between items-center mb-6">
                        <h4 class="font-headline-md text-headline-md text-on-surface">Aylık Gelir Trendi</h4>
                        <div class="flex gap-2">
                            <button class="text-xs font-bold px-3 py-1 rounded-md bg-primary-container text-white">Gelir</button>
                            <button class="text-xs font-bold px-3 py-1 rounded-md bg-surface-container text-on-surface-variant hover:bg-surface-container-high">Gider</button>
                        </div>
                    </div>
                    <div class="flex-1 min-h-[300px] relative">
                        <canvas id="revenueTrendChart"></canvas>
                    </div>
                </div>
                <!-- Category Doughnut Chart -->
                <div class="bg-white p-6 rounded-xl border border-outline-variant shadow-sm flex flex-col">
                    <h4 class="font-headline-md text-headline-md text-on-surface mb-6">Kategori Dağılımı</h4>
                    <div class="flex-1 flex flex-col justify-center items-center relative">
                        <canvas id="categoryDistributionChart"></canvas>
                        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-4">
                            <span class="text-label-sm font-label-sm text-outline uppercase tracking-tighter">Toplam</span>
                            <span class="text-headline-md font-bold">₺1.2M</span>
                        </div>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-2">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#003d9b]"></span>
                            <span class="text-xs text-on-surface-variant font-medium">Kültür</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#fd8b00]"></span>
                            <span class="text-xs text-on-surface-variant font-medium">Macera</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#404446]"></span>
                            <span class="text-xs text-on-surface-variant font-medium">Gastronomi</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#c3c6d6]"></span>
                            <span class="text-xs text-on-surface-variant font-medium">Diğer</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Top Selling Tours Table -->
            <div class="bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden">
                <div class="p-6 border-b border-outline-variant flex justify-between items-center">
                    <h4 class="font-headline-md text-headline-md text-on-surface">En Çok Satan Turlar</h4>
                    <button class="text-primary font-semibold text-body-md hover:underline">Tümünü Gör</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-surface-container-low border-b border-outline-variant">
                            <tr>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Tur Adı</th>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Kategori</th>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Satış Adedi</th>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Toplam Gelir</th>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Trend</th>
                                <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Durum</th>
                            </tr>
                        </thead>
