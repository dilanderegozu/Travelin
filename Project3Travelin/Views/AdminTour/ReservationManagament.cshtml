                            <td class="px-6 py-4 text-on-surface-variant text-body-md">15 Mar 2024</td>
                            <td class="px-6 py-4 text-on-surface text-center font-semibold">4</td>
                            <td class="px-6 py-4 font-bold text-on-surface">₺8.600</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold bg-secondary-fixed text-on-secondary-fixed-variant">Beklemede</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button class="p-2 hover:bg-primary-fixed rounded-lg text-primary transition-colors" title="Detaylar">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>
                                    <button class="p-2 hover:bg-surface-container-highest rounded-lg text-on-surface-variant transition-colors" title="Düzenle">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
