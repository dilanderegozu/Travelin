                                        <span class="material-symbols-outlined text-[20px]">cancel</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <!-- Row 3 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors group">
                            <td class="px-6 py-4 font-bold text-primary">#TRV-8944</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0">
                                        <img class="w-full h-full object-cover" data-alt="A luxury yacht sailing through the crystal clear turquoise waters of the Turkish Riviera in Antalya. The sun is shining brightly, creating sparkling reflections on the water. The mood is exclusive, serene, and premium, using a palette of blues, whites, and subtle golden accents. High-end lifestyle travel photography." src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_-TThz7nd2H6hMU6w0nqfzopvc8mPqL8bFKxM1ma1UIKkjAX7NzJIQC9RQSK5CcCzBUKBVe9b1EKsYi9PlP_x3TLhJ7qayxs2W3MBdOHQHrsdeWb2iWKq83zQSVJX4KHApmzKkXb69Bk7eZ_KP0YZMPqThMCksbzli3wIC-x_UsfJmG14_w6FxkX9AdDzn0I6iU3NmFUQfJgs8fyy4WkKrjF22B-m2GxGUeaKvrUXxq4ZzyzYJbLkXvWJtNDoo3wJo84ZAUt7heM" />
