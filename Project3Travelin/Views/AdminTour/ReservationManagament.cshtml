                                    </button>
                                    <button class="p-2 hover:bg-surface-container-highest rounded-lg text-on-surface-variant transition-colors" title="Düzenle">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </button>
                                    <button class="p-2 hover:bg-error-container rounded-lg text-error transition-colors" title="İptal">
                                        <span class="material-symbols-outlined text-[20px]">cancel</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <!-- Row 2 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors group">
                            <td class="px-6 py-4 font-bold text-primary">#TRV-8943</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0">
                                        <img class="w-full h-full object-cover" data-alt="A professional close-up shot of an ancient Roman amphitheater in Ephesus under a clear blue sky. The stone textures are sharp and detailed. The lighting is bright mid-day sun, creating a majestic and historical atmosphere. Corporate travel brochure style with a clean, light-mode finish." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBx-IDqM68DdB-czEYN87PJCm54xVNPRBzxjUN-PFrWrbY9YDBRawduYUMIDDIbYSXTN3jQmZFq53Mnjwly5nf8b0545F5l36ivTOOZES85eLDAJsNOPcrbgxTUtOcxX997wDSiCdy-Zln-U4vrqj73-wuDtaLgyNsmBibd9Nu6TdodRbAJZr4QXUjca0JBLgbRPYEQSXyl_pIQOvLHJxAUbwESagzFhlllNo_XHRdrBmKm2zjaoGktt6ubn0lp7eJYe_TagbG_xS4" />
