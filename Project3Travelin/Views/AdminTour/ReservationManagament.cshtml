@model List<Project3Travelin.Dtos.ReservationDtos.ResultReservationDto>
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<main class="p-container-padding pb-20 flex-1">
    <section class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
            <h2 class="font-display-lg text-display-lg text-on-surface mb-1">Rezervasyon Yönetimi</h2>
            <p class="text-on-surface-variant font-body-lg text-body-lg">Tüm rezervasyonları görüntüleyin ve durumlarını güncelleyin.</p>
        </div>
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-outline-variant/30 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">confirmation_number</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Toplam Rezervasyon</p>
                <h3 class="text-2xl font-extrabold text-on-surface">@ViewBag.TotalReservations</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-outline-variant/30 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary-fixed flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined">pending_actions</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Onay Bekleyen</p>
                <h3 class="text-2xl font-extrabold text-on-surface">@ViewBag.PendingReservations</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-outline-variant/30 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">verified</span>
            </div>
            <div>
                <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Onaylananlar</p>
                <h3 class="text-2xl font-extrabold text-on-surface">@ViewBag.ApprovedReservations</h3>
            </div>
        </div>
    </section>

    <section class="bg-white rounded-2xl border border-outline-variant/30 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low">
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Müşteri</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Tur</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Tarih</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-center">Kişi</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Durum</th>
                        <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/20">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-surface-container-low/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-primary-fixed flex items-center justify-center font-bold text-primary text-xs">
                                        @(item.FirstName?[0].ToString())@(item.LastName?[0].ToString())
                                    </div>
                                    <div>
                                        <p class="font-bold text-on-surface text-sm">@item.FirstName @item.LastName</p>
                                        <p class="text-on-surface-variant text-xs">@item.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant text-body-md">@item.TourName</td>
                            <td class="px-6 py-4 text-on-surface-variant text-body-md">@item.TourDate.ToString("dd MMM yyyy")</td>
                            <td class="px-6 py-4 text-on-surface text-center font-semibold">@item.PersonCount</td>
                            <td class="px-6 py-4">
                                @if (item.Status == "Onaylandı")
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800">Onaylandı</span>
                                }
                                else if (item.Status == "İptal")
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">İptal</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-800">Beklemede</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    @if (item.Status != "Onaylandı")
                                    {
                                        <form method="post" asp-action="UpdateReservationStatus" asp-controller="AdminTour">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="Onaylandı" />
                                            <button type="submit"
                                                    class="p-2 hover:bg-emerald-50 rounded-lg text-emerald-600 transition-colors"
                                                    title="Onayla">
                                                <span class="material-symbols-outlined text-[20px]">check_circle</span>
                                            </button>
                                        </form>
                                    }
                                    @if (item.Status != "Beklemede")
                                    {
                                        <form method="post" asp-action="UpdateReservationStatus" asp-controller="AdminTour">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="Beklemede" />
                                            <button type="submit"
                                                    class="p-2 hover:bg-amber-50 rounded-lg text-amber-600 transition-colors"
                                                    title="Beklemede">
                                                <span class="material-symbols-outlined text-[20px]">pending</span>
                                            </button>
                                        </form>
                                    }
                                    @if (item.Status != "İptal")
                                    {
                                        <form method="post" asp-action="UpdateReservationStatus" asp-controller="AdminTour"
                                              onsubmit="return confirm('Rezervasyonu iptal etmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="İptal" />
                                            <button type="submit"
                                                    class="p-2 hover:bg-red-50 rounded-lg text-red-600 transition-colors"
                                                    title="İptal Et">
                                                <span class="material-symbols-outlined text-[20px]">cancel</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-6 border-t border-outline-variant/30 flex justify-between items-center">
            <p class="text-on-surface-variant text-body-md">Toplam @Model.Count rezervasyon</p>
        </div>
    </section>
</main>