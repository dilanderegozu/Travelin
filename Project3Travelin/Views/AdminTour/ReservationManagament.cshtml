@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}
    <!-- Main Canvas -->

        <!-- Header Section -->
        <section class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
            <div>
                <h2 class="font-display-lg text-display-lg text-on-surface mb-1">Rezervasyon Yönetimi</h2>
                <p class="text-on-surface-variant font-body-lg text-body-lg">Tüm rezervasyonları görüntüleyin, durumlarını güncelleyin ve ödemeleri takip edin.</p>
            </div>
            <div class="flex gap-3">
                <button class="bg-white border border-outline-variant text-on-surface-variant px-4 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-surface-container transition-all shadow-soft">
                    <span class="material-symbols-outlined">download</span> Dışa Aktar
                </button>
                <button class="bg-primary text-on-primary px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:brightness-110 transition-all shadow-soft">
                    <span class="material-symbols-outlined">add</span> Yeni Kayıt
                </button>
            </div>
        </section>
        <!-- Stats Grid -->
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-6 rounded-2xl shadow-soft border border-outline-variant/30 flex flex-col gap-4">
                <div class="flex justify-between items-start">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">confirmation_number</span>
                    </div>
                    <span class="text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full text-label-sm font-bold flex items-center">
                        <span class="material-symbols-outlined text-[16px]">trending_up</span> +12%
                    </span>
                </div>
                <div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Toplam Rezervasyon</p>
                    <h3 class="text-display-lg text-2xl font-extrabold text-on-surface">1,240</h3>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-soft border border-outline-variant/30 flex flex-col gap-4">
                <div class="flex justify-between items-start">
                    <div class="w-12 h-12 rounded-xl bg-secondary-fixed flex items-center justify-center text-secondary">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">pending_actions</span>
                    </div>
                </div>
                <div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Bekleyen İşlemler</p>
                    <h3 class="text-display-lg text-2xl font-extrabold text-on-surface">42</h3>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-soft border border-outline-variant/30 flex flex-col gap-4">
                <div class="flex justify-between items-start">
                    <div class="w-12 h-12 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">verified</span>
                    </div>
                </div>
                <div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Onaylananlar</p>
                    <h3 class="text-display-lg text-2xl font-extrabold text-on-surface">1,158</h3>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-soft border border-outline-variant/30 flex flex-col gap-4">
                <div class="flex justify-between items-start">
                    <div class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center text-on-primary-container">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
                    </div>
                </div>
                <div>
                    <p class="text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wide">Toplam Gelir</p>
                    <h3 class="text-display-lg text-2xl font-extrabold text-on-surface">₺842.500</h3>
                </div>
            </div>
        </section>
        <!-- Filters & Content -->
        <section class="bg-white rounded-2xl shadow-soft border border-outline-variant/30 overflow-hidden">
            <!-- Filter Bar -->
            <div class="p-6 border-b border-outline-variant/30 flex flex-wrap gap-4 items-center justify-between">
                <div class="flex flex-wrap gap-3">
                    <div class="relative min-w-[200px]">
                        <label class="absolute -top-2 left-3 bg-white px-1 text-[10px] text-primary font-bold uppercase tracking-tight">Durum</label>
                        <select class="w-full border border-outline-variant rounded-lg px-3 py-2 text-body-md focus:ring-2 focus:ring-primary appearance-none bg-no-repeat bg-[right_10px_center] cursor-pointer">
                            <option>Tüm Durumlar</option>
                            <option>Onaylandı</option>
                            <option>Beklemede</option>
                            <option>İptal Edildi</option>
                        </select>
                    </div>
                    <div class="relative min-w-[200px]">
                        <label class="absolute -top-2 left-3 bg-white px-1 text-[10px] text-primary font-bold uppercase tracking-tight">Tarih Aralığı</label>
                        <input class="w-full border border-outline-variant rounded-lg px-3 py-2 text-body-md focus:ring-2 focus:ring-primary" type="date" />
                    </div>
                </div>
                <div class="flex items-center gap-2 text-on-surface-variant font-body-md">
                    <span>Sırala:</span>
                    <button class="font-bold text-primary flex items-center gap-1 hover:underline">
                        Son Eklenen <span class="material-symbols-outlined text-[18px]">expand_more</span>
                    </button>
                </div>
            </div>
            <!-- Table Container -->
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low">
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Rezervasyon ID</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Müşteri &amp; Tur</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Tarih</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-center">Kişi</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Tutar</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider">Durum</th>
                            <th class="px-6 py-4 font-table-header text-table-header text-on-surface-variant uppercase tracking-wider text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        <!-- Row 1 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors group">
                            <td class="px-6 py-4 font-bold text-primary">#TRV-8942</td>
