                                        <p class="text-on-surface-variant text-label-sm">Kapadokya Gün Doğumu Turu</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant text-body-md">14 Mar 2024</td>
                            <td class="px-6 py-4 text-on-surface text-center font-semibold">2</td>
                            <td class="px-6 py-4 font-bold text-on-surface">₺4.250</td>
