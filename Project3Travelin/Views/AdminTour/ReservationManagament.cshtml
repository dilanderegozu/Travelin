                                        <p class="text-on-surface-variant text-label-sm">Antalya Yat Turu</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant text-body-md">18 Mar 2024</td>
                            <td class="px-6 py-4 text-on-surface text-center font-semibold">1</td>
                            <td class="px-6 py-4 font-bold text-on-surface">₺2.100</td>
