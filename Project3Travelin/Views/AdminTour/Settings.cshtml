@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

 <div class="p-8 flex-1">
            <div class="max-w-4xl mx-auto">
                <!-- Header Section -->
                <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
                    <div>
                        <h2 class="font-display-lg text-display-lg text-primary mb-2">Sistem Ayarları</h2>
                        <p class="text-on-surface-variant text-body-lg">Tüm sistem yapılandırmalarını ve kullanıcı tercihlerini tek bir yerden yönetin.</p>
                    </div>
                    <button class="bg-secondary-container hover:bg-secondary text-on-secondary-container hover:text-white px-6 py-3 rounded-lg font-semibold flex items-center gap-2 transition-all shadow-md active:scale-95">
                        <span class="material-symbols-outlined" data-icon="save" style="font-variation-settings: 'FILL' 1;">save</span>
                        Tümünü Kaydet
                    </button>
                </div>
                <!-- Single Column Scrollable Content -->
                <div class="space-y-8 pb-12">
                    <!-- Profile and Identity Card -->
                    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                        <div class="flex items-center gap-2 mb-8 text-primary">
                            <span class="material-symbols-outlined" data-icon="person">person</span>
                            <h3 class="font-headline-md text-headline-md">Profil Bilgileri</h3>
                        </div>
                        <!-- Profil Fotoğrafı Group -->
                        <div class="p-6 bg-surface-container-low rounded-xl flex flex-col md:flex-row items-center gap-8 border border-dashed border-outline-variant mb-8">
                            <div class="w-32 h-32 flex-shrink-0 bg-white rounded-full shadow-inner border-2 border-primary-container flex items-center justify-center overflow-hidden group relative">
                                <img alt="Profil Fotoğrafı" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAgnBRugk2RdTfk41GMvGqduK-VMEJ7_xCSQM1IMYZhAiDDA45nToSmGHm_YIvxs2LlQMZeJNaSJUtZqj4mLqWeR15_Y7Qtq7WladfzXMLWrqtkDVxwy0tVdRfirh8XNVt9ZQDgbR_5wfbyincZEbo9ORDYLbljvCOoD5pfo5qWzq0Dd1gaBZMp0Oq7O0qP3ajho3n7eVj41uTRr9pWjbHJnLS70kVeNLI-qQk-2ODawZ1s2hYic74KiLoyuXYzBMktnMIapirvVVw" />
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity cursor-pointer">
                                    <span class="material-symbols-outlined text-white" data-icon="photo_camera">photo_camera</span>
                                </div>
                            </div>
                            <div class="flex-1 text-center md:text-left">
                                <h4 class="font-bold text-on-surface mb-1">Profil Fotoğrafı</h4>
                                <p class="text-body-md text-on-surface-variant mb-4">Kare formatta, minimum 200x200px boyutunda bir fotoğraf önerilir.</p>
                                <div class="flex flex-wrap justify-center md:justify-start gap-3">
                                    <button class="px-4 py-2 bg-primary text-white rounded-lg text-label-sm font-label-sm hover:bg-primary-container transition-all" type="button">Fotoğrafı Güncelle</button>
                                    <button class="px-4 py-2 bg-transparent border border-outline-variant text-on-surface-variant rounded-lg text-label-sm font-label-sm hover:bg-surface-container transition-all" type="button">Kaldır</button>
                                </div>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Ad Soyad</label>
                                <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="text" value="Admin User" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">E-posta Adresi</label>
                                <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="email" value="admin@travelin.com" />
                            </div>
                        </div>
                    </section>
                    <!-- Security Section -->
                    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                        <div class="flex items-center gap-2 mb-8 text-primary">
                            <span class="material-symbols-outlined" data-icon="shield_person">shield_person</span>
                            <h3 class="font-headline-md text-headline-md">Güvenlik ve Şifre</h3>
                        </div>
                        <div class="grid grid-cols-1 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Mevcut Şifre</label>
                                <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="••••••••" type="password" />
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Yeni Şifre</label>
                                    <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Yeni şifrenizi girin" type="password" />
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Yeni Şifre (Tekrar)</label>
                                    <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Yeni şifrenizi tekrar girin" type="password" />
                                </div>
                            </div>
                        </div>
                        <!-- Footer Security Tip within this section context -->
                        <div class="mt-8 p-4 bg-surface-container-low rounded-lg flex items-start gap-3 border-l-4 border-secondary-container">
                            <span class="material-symbols-outlined text-secondary-container text-[20px]" data-icon="security" style="font-variation-settings: 'FILL' 1;">security</span>
                            <p class="text-body-md text-on-surface-variant italic">Hesap güvenliğiniz için şifrenizi en az 8 karakterden oluşan, karmaşık bir kombinasyonla belirlemeniz önerilir.</p>
                        </div>
                    </section>
                    <!-- Contact Information Card -->
                    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                        <div class="flex items-center gap-2 mb-8 text-primary">
                            <span class="material-symbols-outlined" data-icon="contact_page">contact_page</span>
                            <h3 class="font-headline-md text-headline-md">İletişim Bilgileri</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Telefon Numarası</label>
                                <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="tel" value="+90 212 555 0000" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Destek E-postası</label>
                                <input class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="email" value="support@travelin.com" />
                            </div>
                            <div class="flex flex-col gap-2 md:col-span-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Şirket Adresi</label>
                                <textarea class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all min-h-[100px]" placeholder="Açık adres giriniz...">Levent Mah. Cömert Sk. No:1, Beşiktaş/İstanbul</textarea>
                            </div>
                        </div>
                    </section>
                    <!-- Social Media and Web Presence -->
                    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                        <div class="flex items-center gap-2 mb-8 text-primary">
                            <span class="material-symbols-outlined" data-icon="share">share</span>
                            <h3 class="font-headline-md text-headline-md">Sosyal Medya ve Linkler</h3>
                        </div>
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg"><span class="material-symbols-outlined text-primary" data-icon="language">language</span></span>
                                <input class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Web Sitesi URL" type="url" value="https://www.travelin.com" />
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg"><span class="material-symbols-outlined text-[#1877F2]" data-icon="facebook">facebook</span></span>
                                <input class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Facebook Sayfası" type="text" value="facebook.com/travelin" />
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg"><span class="material-symbols-outlined text-[#E4405F]" data-icon="camera">camera</span></span>
                                <input class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Instagram Kullanıcı Adı" type="text" />
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
        
    </main>
    <script>
        // Micro-interaction: Form input focus glow
        const inputs = document.querySelectorAll('input, select, textarea');
        inputs.forEach(input => {
        input.addEventListener('focus', () => {
        input.parentElement.closest('.flex-col, .flex-1')?.classList.add('scale-[1.005]');
        });
        input.addEventListener('blur', () => {
        input.parentElement.closest('.flex-col, .flex-1')?.classList.remove('scale-[1.005]');
        });
        });
    </script>
