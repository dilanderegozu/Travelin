@model AppUser
@{
    Layout = "~/Views/Shared/_AdminTourLayout.cshtml";
}

<div class="p-8 flex-1">
    <div class="max-w-4xl mx-auto">
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h2 class="font-display-lg text-display-lg text-primary mb-2">Sistem Ayarları</h2>
                <p class="text-on-surface-variant text-body-lg">Tüm sistem yapılandırmalarını ve kullanıcı tercihlerini tek bir yerden yönetin.</p>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm font-semibold">
                @TempData["Success"]
            </div>
        }
        @if (TempData["PasswordSuccess"] != null)
        {
            <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm font-semibold">
                @TempData["PasswordSuccess"]
            </div>
        }
        @if (TempData["PasswordError"] != null)
        {
            <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm font-semibold">
                @TempData["PasswordError"]
            </div>
        }

        <div class="space-y-8 pb-12">

            <!-- Profil Bilgileri -->
            <form method="post" asp-action="UpdateProfile" asp-controller="AdminTour">
                @Html.AntiForgeryToken()
                <section class="bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/30">
                    <div class="flex items-center gap-2 mb-8 text-primary">
                        <span class="material-symbols-outlined">person</span>
                        <h3 class="font-headline-md text-headline-md">Profil Bilgileri</h3>
                    </div>

                    <div class="p-6 bg-surface-container-low rounded-xl flex flex-col md:flex-row items-center gap-8 border border-dashed border-outline-variant mb-8">
                        <div class="w-32 h-32 flex-shrink-0 rounded-full border-2 border-primary-container overflow-hidden bg-primary-fixed flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="w-full h-full object-cover" alt="Profil" />
                            }
                            else
                            {
                                <span class="text-3xl font-bold text-primary">
                                    @(Model?.FirstName?[0].ToString().ToUpper())@(Model?.LastName?[0].ToString().ToUpper())
                                </span>
                            }
                        </div>
                        <div class="flex-1">
                            <h4 class="font-bold text-on-surface mb-1">Profil Fotoğrafı URL</h4>
                            <p class="text-body-md text-on-surface-variant mb-4">Kare formatta, minimum 200x200px boyutunda bir fotoğraf önerilir.</p>
                            <input name="ImageUrl" type="url" value="@Model?.ImageUrl"
                                   class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="https://..." />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Ad</label>
                            <input name="FirstName" type="text" value="@Model?.FirstName"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Soyad</label>
                            <input name="LastName" type="text" value="@Model?.LastName"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">E-posta</label>
                            <input name="Email" type="email" value="@Model?.Email"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Destek E-postası</label>
                            <input name="SupportEmail" type="email" value="@Model?.SupportEmail"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                    </div>

                    <button type="submit"
                            class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-container transition-all shadow-md">
                        Profili Kaydet
                    </button>
                </section>
            </form>

            <!-- Şifre -->
            <form method="post" asp-action="ChangePassword" asp-controller="AdminTour">
                @Html.AntiForgeryToken()
                <section class="bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/30">
                    <div class="flex items-center gap-2 mb-8 text-primary">
                        <span class="material-symbols-outlined">shield_person</span>
                        <h3 class="font-headline-md text-headline-md">Güvenlik ve Şifre</h3>
                    </div>
                    <div class="grid grid-cols-1 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Mevcut Şifre</label>
                            <input name="CurrentPassword" type="password"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="••••••••" />
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Yeni Şifre</label>
                                <input name="NewPassword" type="password"
                                       class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                       placeholder="Yeni şifrenizi girin" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Yeni Şifre (Tekrar)</label>
                                <input name="ConfirmPassword" type="password"
                                       class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                       placeholder="Yeni şifrenizi tekrar girin" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-6 p-4 bg-surface-container-low rounded-lg flex items-start gap-3 border-l-4 border-secondary-container">
                        <span class="material-symbols-outlined text-secondary-container text-[20px]">security</span>
                        <p class="text-body-md text-on-surface-variant italic">Hesap güvenliğiniz için şifrenizi en az 8 karakterden oluşan, karmaşık bir kombinasyonla belirlemeniz önerilir.</p>
                    </div>
                    <button type="submit" class="mt-6 bg-secondary-container text-on-secondary-container px-6 py-3 rounded-lg font-semibold hover:bg-secondary hover:text-white transition-all shadow-md">
                        Şifreyi Güncelle
                    </button>
                </section>
            </form>

            <!-- İletişim Bilgileri -->
            <form method="post" asp-action="UpdateProfile" asp-controller="AdminTour">
                @Html.AntiForgeryToken()
                <input type="hidden" name="FirstName" value="@Model?.FirstName" />
                <input type="hidden" name="LastName" value="@Model?.LastName" />
                <input type="hidden" name="Email" value="@Model?.Email" />
                <input type="hidden" name="ImageUrl" value="@Model?.ImageUrl" />
                <input type="hidden" name="SupportEmail" value="@Model?.SupportEmail" />
                <section class="bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/30">
                    <div class="flex items-center gap-2 mb-8 text-primary">
                        <span class="material-symbols-outlined">contact_page</span>
                        <h3 class="font-headline-md text-headline-md">İletişim Bilgileri</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Telefon</label>
                            <input name="Phone" type="tel" value="@Model?.Phone"
                                   class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                        </div>
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Şirket Adresi</label>
                            <textarea name="Address" rows="3"
                                      class="px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none">@Model?.Address</textarea>
                        </div>
                    </div>
                    <button type="submit" class="mt-6 bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-container transition-all shadow-md">
                        İletişim Bilgilerini Kaydet
                    </button>
                </section>
            </form>

            <!-- Sosyal Medya -->
            <form method="post" asp-action="UpdateProfile" asp-controller="AdminTour">
                @Html.AntiForgeryToken()
                <input type="hidden" name="FirstName" value="@Model?.FirstName" />
                <input type="hidden" name="LastName" value="@Model?.LastName" />
                <input type="hidden" name="Email" value="@Model?.Email" />
                <input type="hidden" name="ImageUrl" value="@Model?.ImageUrl" />
                <input type="hidden" name="Phone" value="@Model?.Phone" />
                <input type="hidden" name="Address" value="@Model?.Address" />
                <input type="hidden" name="SupportEmail" value="@Model?.SupportEmail" />
                <section class="bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/30">
                    <div class="flex items-center gap-2 mb-8 text-primary">
                        <span class="material-symbols-outlined">share</span>
                        <h3 class="font-headline-md text-headline-md">Sosyal Medya ve Linkler</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="flex items-center gap-3">
                            <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg">
                                <span class="material-symbols-outlined text-primary">language</span>
                            </span>
                            <input name="Website" type="url" value="@Model?.Website"
                                   class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="Web Sitesi URL" />
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg">
                                <span class="material-symbols-outlined" style="color:#1877F2;">facebook</span>
                            </span>
                            <input name="Facebook" type="text" value="@Model?.Facebook"
                                   class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="Facebook Sayfası" />
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-lg">
                                <span class="material-symbols-outlined" style="color:#E4405F;">camera</span>
                            </span>
                            <input name="Instagram" type="text" value="@Model?.Instagram"
                                   class="flex-1 px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="Instagram Kullanıcı Adı" />
                        </div>
                    </div>
                    <button type="submit" class="mt-6 bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-container transition-all shadow-md">
                        Sosyal Medyayı Kaydet
                    </button>
                </section>
            </form>

        </div>
    </div>
</div>