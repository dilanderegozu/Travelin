@model List<Project3Travelin.Entities.Reservation>
@{
    Layout = "~/Views/Shared/_TravelinLayout.cshtml";
    ViewData["Title"] = "Rezervasyonlarım";
}

<!-- BreadCrumb -->
<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/images/bg/bg1.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">Rezervasyonlarım</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Dashboard/Index">Ana Sayfa</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Rezervasyonlarım</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<section class="trending pt-6 pb-6 bg-lgrey">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mb-4" style="font-size:13px;">
                @TempData["Success"]
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-times" style="font-size:48px; color:#ccc;"></i>
                <h4 class="mt-3" style="color:#888;">Henüz rezervasyonunuz bulunmuyor.</h4>
                <a href="/Tour/TourList" class="nir-btn mt-3">Turlara Göz At</a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-lg-6 mb-4">
                        <div class="bg-white rounded p-4" style="border:0.5px solid #e0e0e0;">

                            <!-- Üst: Durum + Tarih -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge rounded-pill px-3 py-2"
                                      style="font-size:12px; font-weight:500;
                                    background: @(item.Status == "Onaylandı" ? "#e1f5ee" : item.Status == "İptal" ? "#fdecea" : "#fff8e1");
                                    color: @(item.Status == "Onaylandı" ? "#0F6E56" : item.Status == "İptal" ? "#c0392b" : "#b7770d");">
                                    <i class="fas @(item.Status == "Onaylandı" ? "fa-check-circle" : item.Status == "İptal" ? "fa-times-circle" : "fa-clock") me-1"></i>
                                    @item.Status
                                </span>
                                <small style="color:#9ca3af;">
                                    <i class="fas fa-calendar-alt me-1"></i>
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </small>
                            </div>

                            <!-- Bilgiler -->
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="p-3 rounded" style="background:#f9fafb;">
                                        <p class="mb-0" style="font-size:11px; color:#9ca3af;">Ad Soyad</p>
                                        <p class="mb-0" style="font-size:14px; font-weight:500;">@item.FirstName @item.LastName</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 rounded" style="background:#f9fafb;">
                                        <p class="mb-0" style="font-size:11px; color:#9ca3af;">E-posta</p>
                                        <p class="mb-0" style="font-size:14px; font-weight:500;">@item.Email</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 rounded" style="background:#f9fafb;">
                                        <p class="mb-0" style="font-size:11px; color:#9ca3af;">Tur Tarihi</p>
                                        <p class="mb-0" style="font-size:14px; font-weight:500;">@item.TourDate.ToString("dd MMM yyyy")</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 rounded" style="background:#f9fafb;">
                                        <p class="mb-0" style="font-size:11px; color:#9ca3af;">Kişi Sayısı</p>
                                        <p class="mb-0" style="font-size:14px; font-weight:500;">@item.PersonCount Kişi</p>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(item.Phone))
                                {
                                    <div class="col-6">
                                        <div class="p-3 rounded" style="background:#f9fafb;">
                                            <p class="mb-0" style="font-size:11px; color:#9ca3af;">Telefon</p>
                                            <p class="mb-0" style="font-size:14px; font-weight:500;">@item.Phone</p>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    <div class="col-12">
                                        <div class="p-3 rounded" style="background:#f9fafb;">
                                            <p class="mb-0" style="font-size:11px; color:#9ca3af;">Not</p>
                                            <p class="mb-0" style="font-size:14px;">@item.Note</p>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Alt: İptal Butonu -->
                            @if (item.Status != "İptal")
                            {
                                <form method="post" asp-action="Delete" asp-controller="Reservation"
                                      onsubmit="return confirm('Rezervasyonu iptal etmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id">
                                    <button type="submit" class="btn w-100"
                                            style="border:0.5px solid #e0e0e0; font-size:13px; color:#c0392b; font-weight:500; padding:8px;">
                                        <i class="fas fa-times-circle me-1"></i> Rezervasyonu İptal Et
                                    </button>
                                </form>
                            }

                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>