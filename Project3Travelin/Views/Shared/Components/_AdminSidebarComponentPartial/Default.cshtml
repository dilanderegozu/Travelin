@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var turAltMenu = new[] { "TourList", "CreateTour", "TourCategory", "TourDate" }.Contains(action);
    string aktif = "bg-surface-container-highest text-primary font-semibold border-l-4 border-primary";
    string pasif = "text-on-surface-variant hover:bg-surface-container rounded-lg";
}

<aside class="flex flex-col h-screen fixed left-0 top-0 z-40 w-[sidebar-width] bg-surface border-r border-outline-variant">
    <div class="p-6">
        <h1 class="font-headline-md text-headline-md font-extrabold text-primary tracking-tight">Travelin Admin</h1>
        <p class="text-label-sm text-on-surface-variant">Yönetim Paneli</p>
    </div>
    <nav class="flex-1 overflow-y-auto custom-scrollbar px-2 space-y-1">

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "Index" ? aktif : pasif)"
           href="/AdminTour/Index">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="font-body-md">Ana Sayfa</span>
        </a>

        <div class="space-y-1">
            <button id="dropdown-btn"
                    class="w-full flex items-center justify-between gap-3 px-4 py-3 transition-all @(turAltMenu ? aktif : pasif)">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined">explore</span>
                    <span class="font-body-md">Tur Yönetimi</span>
                </div>
                <span class="material-symbols-outlined text-sm transition-transform duration-200 arrow-icon">expand_more</span>
            </button>

            <div id="dropdown-menu" class="pl-12 py-1 space-y-1 @(turAltMenu ? "" : "hidden")">
                <a class="block text-body-md py-2 @(action == "TourList" ? "text-primary font-bold border-b-2 border-primary/20" : "text-on-surface-variant hover:text-primary")"
                   href="/AdminTour/TourList">Tur Listesi</a>
                <a class="block text-body-md py-2 @(action == "CreateTour" ? "text-primary font-bold border-b-2 border-primary/20" : "text-on-surface-variant hover:text-primary")"
                   href="/AdminTour/CreateTour">Yeni Tur Ekle</a>
                <a class="block text-body-md py-2 @(action == "TourCategory" ? "text-primary font-bold border-b-2 border-primary/20" : "text-on-surface-variant hover:text-primary")"
                   href="/AdminTour/TourCategory">Tur Kategorileri</a>
                <a class="block text-body-md py-2 @(action == "TourDate" ? "text-primary font-bold border-b-2 border-primary/20" : "text-on-surface-variant hover:text-primary")"
                   href="/AdminTour/TourDate">Tur Takvimi</a>
            </div>
        </div>

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "ReservationManagament" ? aktif : pasif)"
           href="/AdminTour/ReservationManagament">
            <span class="material-symbols-outlined">confirmation_number</span>
            <span class="font-body-md">Rezervasyon Yönetimi</span>
        </a>

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "CustomerManagament" ? aktif : pasif)"
           href="/AdminTour/CustomerManagament">
            <span class="material-symbols-outlined">group</span>
            <span class="font-body-md">Müşteri Yönetimi</span>
        </a>

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "Report" ? aktif : pasif)"
           href="/AdminTour/Report">
            <span class="material-symbols-outlined">payments</span>
            <span class="font-body-md">Raporlar</span>
        </a>

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "CustomerComment" ? aktif : pasif)"
           href="/AdminTour/CustomerComment">
            <span class="material-symbols-outlined">reviews</span>
            <span class="font-body-md">Yorumlar</span>
        </a>

        <a class="flex items-center gap-3 px-4 py-3 transition-colors @(action == "Settings" ? aktif : pasif)"
           href="/AdminTour/Settings">
            <span class="material-symbols-outlined">settings</span>
            <span class="font-body-md">Ayarlar</span>
        </a>

    </nav>
    <div class="p-4 border-t border-outline-variant">
        <button class="w-full flex items-center gap-3 text-error px-4 py-3 hover:bg-error-container/20 transition-colors rounded-lg">
            <span class="material-symbols-outlined">logout</span>
            <span class="font-body-md">Çıkış Yap</span>
        </button>
    </div>
</aside>