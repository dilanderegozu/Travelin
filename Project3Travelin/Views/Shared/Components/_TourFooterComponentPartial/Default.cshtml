    <div class="footer-upper pb-4">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-6 col-sm-12 mb-4 pe-4">
                    <div class="footer-about">
                        <img src="/travelin/images/logo-white.png" alt="">
                        <p class="mt-3 mb-3 white">
                            Seyahat etmeyi kolay, güvenli ve keyifli hale getiriyoruz. Binlerce gezginin tercih ettiği tur seçenekleriyle, dünyanın dört bir yanındaki eşsiz rotaları keşfetmenize yardımcı oluyoruz. Uygun fiyatlar, profesyonel rehberlik ve kusursuz organizasyon anlayışımızla unutulmaz anılar biriktirmeniz için çalışıyoruz. Bir sonraki maceranız burada başlıyor.
                        </p>
                        <ul>
                            <li class="white"><strong>İletişim:</strong> +90 212 123 45 67</li>
                            <li class="white"><strong>Merkez Ofis:</strong> İstanbul, Türkiye</li>
                            <li class="white"><strong>E-posta:</strong> info@travelin.com</li>
                            <li class="white"><strong>Web:</strong> www.travelin.com</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        <h3 class="white">Hızlı Link </h3>
                        <ul>
                            <li><a href="about-us.html">Hakkımızda</a></li>
                            <li><a href="tours.html">Turlarımız</a></li>
                            <li><a href="destinations.html">Destinasyonlar</a></li>
                            <li><a href="privacy-policy.html">Gizlilik Politikası</a></li>
                            <li><a href="contact.html">İletişim</a></li>
                            <li><a href="terms.html">Rezervasyon Şartları</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        <h3 class="white">Kategoriler</h3>
                        <ul>
                            @foreach (var item in Model.GroupBy(x=>x.CategoryName).Select(x=>x.First()))
                            {
                                <li><a href="">@item.CategoryName</a></li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                    <div class="footer-links">
                        <h3 class="white">Bültenimize Abone Olun</h3>
                        <div class="newsletter-form">
                            <p class="mb-3">
                                En yeni tur fırsatları, özel kampanyalar ve seyahat önerilerinden ilk siz haberdar olun.
                            </p>
                            <form action="#" method="get" accept-charset="utf-8" class="border-0 d-flex align-items-center">
                                <input type="text" placeholder="E-posta Adresiniz">
                                <button class="nir-btn ms-2">Abone Ol</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-payment">
        <div class="container">
            <div class="row footer-pay align-items-center justify-content-between text-lg-start text-center">
                <div class="col-lg-8 footer-payment-nav mb-4">
                    <ul>
                        <li class="me-2">Desteklenen Ödeme Yöntemleri:</li>
                        <li class="me-2"><i class="fab fa-cc-mastercard fs-4"></i></li>
                        <li class="me-2"><i class="fab fa-cc-paypal fs-4"></i></li>
                        <li class="me-2"><i class="fab fa-cc-stripe fs-4"></i></li>
                        <li class="me-2"><i class="fab fa-cc-visa fs-4"></i></li>
                        <li class="me-2"><i class="fab fa-cc-discover fs-4"></i></li>
                    </ul>
                </div>

                <div class="col-lg-4 footer-payment-nav mb-4">
                    <ul class="d-flex align-items-center">
                        <li class="me-2">
                            <a href="#" onclick="changeLanguage('tr')"
                               style="padding:6px 12px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none;">
                                🇹🇷 Türkçe
                            </a>
                        </li>
                        <li>
                            <a href="#" onclick="changeLanguage('en')"
                               style="padding:6px 12px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none;">
                                🇬🇧 English
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-copyright">
        <div class="container">
            <div class="copyright-inner rounded p-3 d-md-flex align-items-center justify-content-between">
                <div class="copyright-text">
                    <p class="m-0 white">@DateTime.Now.Year Travelin. Tüm Hakları Saklıdır.</p>
                </div>
                <div class="social-links">
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
                        <li><a href="#"><i class="fab fa-linkedin" aria-hidden="true"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div id="particles-js"></div>
</footer>