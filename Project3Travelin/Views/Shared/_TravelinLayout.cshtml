@{
    Layout = null;
    
}
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="zxx">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Travelin - Travel Tour Booking HTML Templates</title>
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="images/favicon.png" />
    <!-- Bootstrap core CSS -->
    <link href="/travelin/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!--Custom CSS-->
    <link href="/travelin/css/style.css" rel="stylesheet" type="text/css" />
    <!--Plugin CSS-->
    <link href="/travelin/css/plugin.css" rel="stylesheet" type="text/css" />

    <!--Font Awesome-->

    <link rel="stylesheet" href="/travelin/css/fontawesome.min.css" />

    <link rel="stylesheet" href="/travelin/fonts/line-icons.css" type="text/css" />
</head>

<body>
    <!-- Preloader -->
    <div id="preloader">
        <div id="status"></div>
    </div>
    <!-- Preloader Ends -->
    <!-- header starts -->
    @await Component.InvokeAsync("_DashboardHeadeComponentPartial")
 
    <!-- header ends -->
    <div class="tet"></div>

   @RenderBody()
  

    @await Component.InvokeAsync("_TourFooterComponentPartial")
   
    <!-- search popup -->
    <div id="search1">
        <button type="button" class="close">×</button>
        <form>
            <input type="search" value="" placeholder="type keyword(s) here" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

 
    <script>

                  function googleTranslateElementInit() {
                new google.translate.TranslateElement({
                    pageLanguage: 'tr',
                    includedLanguages: 'tr,en',
                    autoDisplay: false
                }, 'google_translate_element');
            }

            function changeLanguage(lang) {
                const select = document.querySelector('.goog-te-combo');
                if (select) {
                    select.value = lang;
                    select.dispatchEvent(new Event('change'));
                    localStorage.setItem('lang', lang);
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const lang = localStorage.getItem('lang');
                if (lang && lang !== 'tr') {
                    setTimeout(() => changeLanguage(lang), 1500);
                }
            });
            function switchTab(name) {
                document.getElementById('pane-login').style.display = name === 'login' ? 'block' : 'none';
                document.getElementById('pane-register').style.display = name === 'register' ? 'block' : 'none';

                const loginBtn = document.getElementById('tab-login');
                const registerBtn = document.getElementById('tab-register');

                if (name === 'login') {
                    loginBtn.style.background = '#fff';
                    loginBtn.style.border = '0.5px solid #e0e0e0';
                    loginBtn.style.color = '#111';
                    registerBtn.style.background = 'transparent';
                    registerBtn.style.border = 'none';
                    registerBtn.style.color = '#6b7280';
                } else {
                    registerBtn.style.background = '#fff';
                    registerBtn.style.border = '0.5px solid #e0e0e0';
                    registerBtn.style.color = '#111';
                    loginBtn.style.background = 'transparent';
                    loginBtn.style.border = 'none';
                    loginBtn.style.color = '#6b7280';
                }
            }
    </script>

    <!-- *Scripts* -->
    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <script src="/travelin/js/jquery-3.5.1.min.js"></script>
    <script src="/travelin/js/bootstrap.min.js"></script>
    <script src="/travelin/js/fontawesome.min.js"></script>
    <script src="/travelin/js/particles.js"></script>
    <script src="/travelin/js/particlerun.js"></script>
    <script src="/travelin/js/plugin.js"></script>
    <script src="/travelin/js/main.js"></script>
    <script src="/travelin/js/custom-swiper.js"></script>
    <script src="/travelin/js/custom-nav.js"></script>
    @RenderSection("Script",required:false)
</body>
</html>
