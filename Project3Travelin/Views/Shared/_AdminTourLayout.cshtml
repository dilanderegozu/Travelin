@{
    Layout = null;
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>

<html class="light" lang="tr">
    <head>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Travelin Admin</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "tertiary-container": "#575b5e",
                    "on-tertiary-fixed": "#181c1e",
                    "on-primary-container": "#c4d2ff",
                    "surface-tint": "#0c56d0",
                    "primary-fixed": "#dae2ff",
                    "surface-container": "#e7eeff",
                    "secondary": "#904d00",
                    "primary": "#003d9b",
                    "secondary-fixed-dim": "#ffb77d",
                    "on-secondary": "#ffffff",
                    "on-primary-fixed-variant": "#0040a2",
                    "on-secondary-fixed-variant": "#6e3900",
                    "on-surface": "#101c2d",
                    "inverse-primary": "#b2c5ff",
                    "surface-container-highest": "#d7e3fb",
                    "secondary-fixed": "#ffdcc3",
                    "surface-container-high": "#dee9ff",
                    "outline-variant": "#c3c6d6",
                    "inverse-surface": "#253143",
                    "error": "#ba1a1a",
                    "on-primary": "#ffffff",
                    "primary-container": "#0052cc",
                    "primary-fixed-dim": "#b2c5ff",
                    "inverse-on-surface": "#ebf1ff",
                    "surface-dim": "#cedbf2",
                    "tertiary-fixed-dim": "#c3c7ca",
                    "on-tertiary-container": "#d0d3d6",
                    "secondary-container": "#fd8b00",
                    "surface-container-lowest": "#ffffff",
                    "on-background": "#101c2d",
                    "surface": "#f9f9ff",
                    "background": "#f9f9ff",
                    "on-tertiary-fixed-variant": "#43474a",
                    "outline": "#737685",
                    "error-container": "#ffdad6",
                    "on-secondary-fixed": "#2f1500",
                    "on-tertiary": "#ffffff",
                    "surface-variant": "#d7e3fb",
                    "on-surface-variant": "#434654",
                    "on-error-container": "#93000a",
                    "on-secondary-container": "#603100",
                    "surface-bright": "#f9f9ff",
                    "on-error": "#ffffff",
                    "on-primary-fixed": "#001848",
                    "tertiary-fixed": "#e0e3e6",
                    "surface-container-low": "#f0f3ff",
                    "tertiary": "#404446"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "8px",
                    "xl": "12px",
                    "full": "9999px"
            },
            "spacing": {
                    "sidebar-width": "260px",
                    "base": "8px",
                    "container-padding": "24px",
                    "gutter": "16px",
                    "header-height": "70px"
            },
            "fontFamily": {
                    "body-lg": ["Inter"],
                    "body-md": ["Inter"],
                    "display-lg-mobile": ["Inter"],
                    "headline-md": ["Inter"],
                    "display-lg": ["Inter"],
                    "label-sm": ["Inter"],
                    "table-header": ["Inter"]
            },
            "fontSize": {
                    "body-lg": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                    "display-lg-mobile": ["24px", {"lineHeight": "32px", "fontWeight": "700"}],
                    "headline-md": ["20px", {"lineHeight": "28px", "fontWeight": "600"}],
                    "display-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                    "label-sm": ["12px", {"lineHeight": "16px", "fontWeight": "600"}],
                    "table-header": ["13px", {"lineHeight": "18px", "fontWeight": "600"}]
            }
          },
        },
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
        body { font-family: 'Inter', sans-serif; background-color: #F4F7FA; color: #101c2d; }
        .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .sidebar-active-indicator { width: 4px; height: 100%; position: absolute; left: 0; top: 0; background-color: #003d9b; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #c3c6d6; border-radius: 10px; }

        .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        grid-auto-rows: minmax(120px, auto);
        }

        .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body class="bg-surface">
    <!-- Success Toast -->
    <div class="fixed top-6 right-6 z-[100] transform translate-x-[150%] transition-transform duration-500 ease-out" id="success-toast">
        <div class="flex items-center gap-3 bg-white border-l-4 border-emerald-500 px-4 py-3 rounded-lg shadow-xl">
            <span class="material-symbols-outlined text-emerald-500">check_circle</span>
            <div class="flex flex-col">
                <span class="font-bold text-body-md">Başarılı</span>
                <span class="text-body-md text-on-surface-variant">Tur başarıyla güncellendi.</span>
            </div>
            <button class="ml-4 text-outline hover:text-on-surface" onclick="toggleToast()"><span class="material-symbols-outlined">close</span></button>
        </div>
    </div>
    <!-- SideNavBar -->
    @await Component.InvokeAsync("_AdminSidebarComponentPartial")
    <!-- Content Area -->
    <main class="ml-[260px] min-h-screen flex flex-col">
        <!-- TopNavBar -->
        @await Component.InvokeAsync("_AdminNavbarComponentPartial")
        <!-- Main Content Canvas -->
            @RenderBody()
        <!-- Footer -->
        @await Component.InvokeAsync("_AdminFooterComponentPartial")
    </main>
    <!-- Delete Confirmation Modal -->
    <div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-[#091E42]/50 backdrop-blur-sm hidden" id="delete-modal">
        <div class="bg-white w-full max-w-md rounded-xl p-6 shadow-2xl scale-95 transition-transform duration-300">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 rounded-full bg-error-container/30 flex items-center justify-center text-error">
                    <span class="material-symbols-outlined text-[32px]">warning</span>
                </div>
                <button class="text-outline hover:text-on-surface" onclick="toggleModal()"><span class="material-symbols-outlined">close</span></button>
            </div>
            <h3 class="font-headline-md text-headline-md text-on-surface mb-2">Turu Sil?</h3>
            <p class="text-body-md text-on-surface-variant mb-6">Bu turu silmek istediğinizden emin misiniz? Bu işlem geri alınamaz ve tüm rezervasyon verilerini etkileyebilir.</p>
            <div class="flex gap-3 justify-end">
                <button class="px-6 py-2 border border-outline-variant text-on-surface font-semibold rounded-lg hover:bg-surface-container transition-colors" onclick="toggleModal()">Vazgeç</button>
                <button class="px-6 py-2 bg-error text-white font-bold rounded-lg hover:bg-red-700 transition-colors">Sil</button>
            </div>
        </div>
    </div>
    @await Component.InvokeAsync("_AdminScriptComponentPartial")
    @RenderSection("Scripts", required: false)
</body></html>